# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT authentication
SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini (chat / explanations)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_TIMEOUT=30

# OpenCage geocoding (district / state from lat-lon)
OPENCAGE_API_KEY=

# Optional: AWS S3 bucket for file storage
AWS_BUCKET_NAME=

# CORS (comma-separated origins; regex for extra patterns)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https://.*\.ngrok-free\.dev
